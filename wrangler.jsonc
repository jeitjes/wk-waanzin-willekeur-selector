{
  // Cloudflare Worker die de repo-root als statische site serveert (kwimhub.com).
  "name": "kwimhub",
  "compatibility_date": "2026-07-01",
  "routes": [
    { "pattern": "kwimhub.com", "custom_domain": true },
    { "pattern": "www.kwimhub.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page"
  }
}
